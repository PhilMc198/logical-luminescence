---
const currentPath = Astro.url.pathname;
---

<header class="sticky top-0 z-50 backdrop-blur-md bg-cosmic-deep/80 border-b border-neural-teal/20">
  <nav class="max-w-7xl mx-auto px-6 py-4">
    <div class="flex items-center justify-between">
      <!-- Logo -->
      <a href="/" class="text-2xl font-display font-bold bg-gradient-to-r from-golden-glow via-golden-core to-neural-teal bg-clip-text text-transparent hover:opacity-80 transition-opacity">
        Logical Luminescence
      </a>

      <!-- Navigation -->
      <ul class="hidden md:flex items-center gap-8">
        <li>
          <a 
            href="/insights" 
            class={`hover:text-neural-teal transition-colors ${currentPath.startsWith('/insights') ? 'text-neural-teal' : 'text-slate-300'}`}
          >
            Insights
          </a>
        </li>
        <li>
          <a 
            href="/frameworks" 
            class={`hover:text-neural-teal transition-colors ${currentPath.startsWith('/frameworks') ? 'text-neural-teal' : 'text-slate-300'}`}
          >
            Frameworks
          </a>
        </li>
        <li>
          <a 
            href="/exercises" 
            class={`hover:text-neural-teal transition-colors ${currentPath.startsWith('/exercises') ? 'text-neural-teal' : 'text-slate-300'}`}
          >
            Exercises
          </a>
        </li>
        <li>
          <a 
            href="/case-studies" 
            class={`hover:text-neural-teal transition-colors ${currentPath.startsWith('/case-studies') ? 'text-neural-teal' : 'text-slate-300'}`}
          >
            Case Studies
          </a>
        </li>
      </ul>

      <!-- Mobile menu button -->
      <button 
        id="mobile-menu-button"
        class="md:hidden text-slate-300 hover:text-neural-teal"
        aria-label="Toggle menu"
      >
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"></path>
        </svg>
      </button>
    </div>

    <!-- Mobile menu -->
    <div id="mobile-menu" class="hidden md:hidden mt-4 pb-4">
      <ul class="flex flex-col gap-4">
        <li><a href="/insights" class="block hover:text-neural-teal transition-colors">Insights</a></li>
        <li><a href="/frameworks" class="block hover:text-neural-teal transition-colors">Frameworks</a></li>
        <li><a href="/exercises" class="block hover:text-neural-teal transition-colors">Exercises</a></li>
        <li><a href="/case-studies" class="block hover:text-neural-teal transition-colors">Case Studies</a></li>
      </ul>
    </div>
  </nav>
</header>

<script>
  const button = document.getElementById('mobile-menu-button');
  const menu = document.getElementById('mobile-menu');
  
  button?.addEventListener('click', () => {
    menu?.classList.toggle('hidden');
  });
</script>