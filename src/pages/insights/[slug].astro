---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';

export async function getStaticPaths() {
  const insights = await getCollection('insights');
  return insights.map(insight => ({
    params: { slug: insight.slug },
    props: { insight },
  }));
}

const { insight } = Astro.props;
const { Content } = await insight.render();
---

<BaseLayout title={insight.data.title} description={insight.data.excerpt}>
  <Header />
  
  <main class="max-w-4xl mx-auto px-6 py-12">
    <article>
      <!-- Header -->
      <header class="mb-12">
        <div class="mb-4">
          <span class={`inline-block text-xs uppercase tracking-wide font-semibold px-3 py-1 rounded ${
            insight.data.difficulty === 'beginner' ? 'bg-green-400/20 text-green-400' :
            insight.data.difficulty === 'intermediate' ? 'bg-golden-glow/20 text-golden-glow' :
            insight.data.difficulty === 'advanced' ? 'bg-red-400/20 text-red-400' :
            'bg-lavender-soft/20 text-lavender-soft'
          }`}>
            {insight.data.difficulty}
          </span>
        </div>
        
        <h1 class="text-5xl font-display font-bold mb-6 bg-gradient-to-r from-golden-glow to-neural-teal bg-clip-text text-transparent">
          {insight.data.title}
        </h1>
        
        <div class="flex flex-wrap items-center gap-4 text-slate-400 mb-6">
          <time datetime={insight.data.date.toISOString()}>
            {insight.data.date.toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' })}
          </time>
          <span>•</span>
          <span>{insight.data.readingTime} min read</span>
        </div>

        <!-- Tags -->
        <div class="flex flex-wrap gap-2">
          {insight.data.cognitive_domains.map(domain => (
            <span class="text-xs px-3 py-1 bg-lavender-soft/20 border border-lavender-soft/30 rounded-full text-lavender-soft">
              {domain}
            </span>
          ))}
          {insight.data.ai_applications.map(app => (
            <span class="text-xs px-3 py-1 bg-neural-teal/20 border border-neural-teal/30 rounded-full text-neural-teal">
              {app}
            </span>
          ))}
        </div>
      </header>

      <!-- Content -->
      <div class="prose prose-invert prose-lg max-w-none
        prose-headings:font-display prose-headings:text-neural-teal
        prose-h2:text-3xl prose-h3:text-2xl
        prose-p:text-slate-300 prose-p:leading-relaxed
        prose-a:text-golden-glow prose-a:no-underline hover:prose-a:text-golden-core
        prose-strong:text-slate-200
        prose-code:text-neural-teal prose-code:bg-cosmic-blue/60 prose-code:px-1 prose-code:rounded
        prose-pre:bg-cosmic-blue/60 prose-pre:border prose-pre:border-neural-teal/20
        prose-ul:text-slate-300 prose-ol:text-slate-300
        prose-li:marker:text-neural-teal
        prose-blockquote:border-l-neural-teal prose-blockquote:text-slate-400
      ">
        <Content />
      </div>
    </article>
  </main>

  <Footer />
</BaseLayout>