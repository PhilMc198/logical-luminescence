---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getAllEssays, getFeaturedEssays } from '../utils/content';
import { readingTime, readingTimeLabel } from '../utils/readingTime';

const essays = await getAllEssays();
const featured = essays.slice(0, 3);

const pillarLabels: Record<string, string> = {
  'inner-life':            'The inner life',
  'technological-reality': 'Technological reality',
  'power-and-economy':     'Power and economy',
  'adaptation-and-agency': 'Adaptation and agency',
};
---

<BaseLayout
  title="Logical Luminescence"
  description="Exploring the inner life, the technological reality, and the political stakes of a world transformed by AI."
>
  <!-- Hero -->
  <section class="hero">
    <div class="container--narrow">
      <p class="eyebrow">Logical Luminescence</p>
      <h1 class="hero-title">
        Finding your footing<br />
        in a world being<br />
        <em>remade by machines</em>
      </h1>
      <p class="hero-sub">
        AI and autonomous systems are not just changing what we do. They are changing
        who holds power, how wealth flows, and what it means to live a free and
        considered life. This site explores what it takes to stay oriented — inwardly,
        technologically, and politically.
      </p>
      <div class="hero-actions">
        <a href="/start-here" class="btn btn--primary">Start here</a>
        <a href="/essays" class="btn btn--ghost">Read the essays</a>
      </div>
    </div>
  </section>

  <hr class="divider" />

  <!-- Four pillars -->
  <section class="pillars-section">
    <div class="container">
      <p class="eyebrow" style="margin-bottom: 1.75rem;">Four themes</p>
      <div class="pillar-grid">
        <div class="pillar">
          <div class="pillar-num">I</div>
          <div class="pillar-title">The inner life</div>
          <p class="pillar-body">Contemplative practice and self-knowledge as navigation tools, not retreats from the world.</p>
        </div>
        <div class="pillar">
          <div class="pillar-num">II</div>
          <div class="pillar-title">The technological reality</div>
          <p class="pillar-body">Honest assessment of AI — what it is, what it isn't, and what its proliferation actually means.</p>
        </div>
        <div class="pillar">
          <div class="pillar-num">III</div>
          <div class="pillar-title">Power and political economy</div>
          <p class="pillar-body">Wealth concentration, democratic strain, and what history suggests tends to follow.</p>
        </div>
        <div class="pillar">
          <div class="pillar-num">IV</div>
          <div class="pillar-title">Adaptation and agency</div>
          <p class="pillar-body">How individuals and communities find genuine footing and flourishing within the transition.</p>
        </div>
      </div>
    </div>
  </section>

  <hr class="divider" />

  <!-- Essays -->
  <section class="essays-section">
    <div class="container">
      <div class="essays-header">
        <p class="eyebrow">Recent essays</p>
        <a href="/essays" class="essays-all">All essays →</a>
      </div>
      {featured.length > 0 ? (
        <ul class="essay-list" role="list">
          {featured.map((essay) => {
            const mins = essay.data.readingTimeOverride ?? readingTime(essay.body ?? '');
            const pillarLabel = essay.data.pillar ? pillarLabels[essay.data.pillar] : null;
            return (
              <li class="essay-row">
                <a href={`/essays/${essay.id}`} class="essay-link">
                  <div class="essay-main">
                    <span class="essay-title">{essay.data.title}</span>
                    {essay.data.description && (
                      <span class="essay-desc">{essay.data.description}</span>
                    )}
                  </div>
                  <div class="essay-meta">
                    {readingTimeLabel(mins)}
                    {pillarLabel && <span class="essay-pillar">{pillarLabel}</span>}
                  </div>
                </a>
              </li>
            );
          })}
        </ul>
      ) : (
        <p class="essays-empty">Essays coming soon.</p>
      )}
    </div>
  </section>

  <!-- Pull quote -->
  <section class="quote-section">
    <div class="container--narrow">
      <blockquote class="site-pull-quote">
        The examined life, in an automated world, is not a luxury. It is a navigational tool.
      </blockquote>
    </div>
  </section>
</BaseLayout>

<style>
  /* Hero */
  .hero {
    padding: 5rem 0 4rem;
  }

  .hero-title {
    margin: 1.25rem 0 1.5rem;
    line-height: 1.1;
  }

  .hero-title em { font-style: italic; }

  .hero-sub {
    max-width: 520px;
    margin-bottom: 2.5rem;
    font-size: 1.0625rem;
    line-height: 1.8;
  }

  .hero-actions {
    display: flex;
    gap: 1rem;
    align-items: center;
    flex-wrap: wrap;
  }

  /* Pillars */
  .pillars-section {
    padding: 3rem 0;
  }

  .pillar-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1px;
    background: var(--color-border);
    border: 0.5px solid var(--color-border);
  }

  .pillar {
    background: var(--color-ground);
    padding: 1.5rem;
  }

  .pillar-num {
    font-family: var(--font-serif);
    font-size: 1.8rem;
    color: var(--color-border);
    line-height: 1;
    margin-bottom: 0.5rem;
  }

  .pillar-title {
    font-size: 13px;
    color: var(--color-ink);
    margin-bottom: 0.4rem;
    font-weight: 400;
  }

  .pillar-body {
    font-size: 12px;
    color: var(--color-ink-muted);
    line-height: 1.65;
  }

  /* Essays */
  .essays-section {
    padding: 3rem 0;
  }

  .essays-header {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    margin-bottom: 1.5rem;
  }

  .essays-all {
    font-size: 12px;
    color: var(--color-ink-muted);
    transition: color 0.15s;
  }

  .essays-all:hover { color: var(--color-ink); }

  .essay-list {
    list-style: none;
  }

  .essay-row {
    border-bottom: 0.5px solid var(--color-border-mid);
  }

  .essay-link {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: 1.5rem;
    padding: 1.1rem 0;
    text-decoration: none;
    transition: opacity 0.15s;
  }

  .essay-link:hover { opacity: 0.7; }

  .essay-main {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    min-width: 0;
  }

  .essay-title {
    font-family: var(--font-serif);
    font-size: 1.15rem;
    color: var(--color-ink);
    font-weight: 400;
  }

  .essay-desc {
    font-size: 12px;
    color: var(--color-ink-muted);
    line-height: 1.5;
  }

  .essay-meta {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 0.25rem;
    font-size: 11px;
    color: var(--color-ink-faint);
    white-space: nowrap;
    flex-shrink: 0;
  }

  .essay-pillar {
    font-size: 10px;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    color: var(--color-ink-faint);
  }

  .essays-empty {
    color: var(--color-ink-faint);
    font-size: 14px;
    padding: 1rem 0;
  }

  /* Pull quote */
  .quote-section {
    padding: 3rem 0 4rem;
  }

  .site-pull-quote {
    font-family: var(--font-serif);
    font-size: clamp(1.2rem, 2.5vw, 1.5rem);
    font-style: italic;
    color: var(--color-ink-mid);
    line-height: 1.55;
    border-left: 2px solid var(--color-border);
    padding: 0.4rem 0 0.4rem 1.5rem;
    font-weight: 400;
  }

  /* Responsive */
  @media (max-width: 560px) {
    .pillar-grid { grid-template-columns: 1fr; }
    .essay-link { flex-direction: column; gap: 0.4rem; }
    .essay-meta { align-items: flex-start; flex-direction: row; gap: 0.75rem; }
  }
</style>
