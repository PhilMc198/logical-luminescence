---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Card from '../components/Card.astro';
import { getCollection } from 'astro:content';

// Get featured insights
const allInsights = await getCollection('insights');
const featuredInsights = allInsights
  .filter(insight => insight.data.featured)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 3);
---

<BaseLayout title="Home">
  <Header />
  
  <main>
    <!-- Hero Section -->
    <section class="max-w-7xl mx-auto px-6 py-20">
      <div class="grid md:grid-cols-2 gap-12 items-center">
        <div>
          <h1 class="text-5xl md:text-6xl font-display font-bold mb-6">
            <span class="block bg-gradient-to-r from-golden-glow via-golden-core to-neural-teal bg-clip-text text-transparent">
              Logical Luminescence
            </span>
          </h1>
          <p class="text-2xl text-slate-300 mb-6">
            Illuminating the intersection of human cognition and artificial intelligence
          </p>
          <p class="text-lg text-slate-400 mb-8">
            Explore how understanding the brain's Default Mode Network can transform your collaboration with AI systems—creating mindful, effective, and sustainable human-AI partnerships.
          </p>
          <div class="flex gap-4">
            <a href="/insights" class="px-6 py-3 bg-gradient-to-r from-golden-core to-golden-glow rounded-lg text-cosmic-deep font-semibold hover:shadow-glow-md transition-all duration-300">
              Explore Insights
            </a>
            <a href="/frameworks" class="px-6 py-3 border-2 border-neural-teal text-neural-teal rounded-lg font-semibold hover:bg-neural-teal/10 transition-all duration-300">
              View Frameworks
            </a>
          </div>
        </div>

        <!-- Cosmic Sphere Visualization -->
        <div class="relative h-96 flex items-center justify-center">
          <div class="relative">
            <!-- Core -->
            <div class="w-32 h-32 bg-gradient-to-br from-golden-core to-golden-glow rounded-full blur-sm animate-pulse"></div>
            
            <!-- Rings -->
            <div class="absolute inset-0 flex items-center justify-center">
              <div class="w-48 h-48 border-2 border-neural-teal/30 rounded-full animate-spin-slow"></div>
            </div>
            <div class="absolute inset-0 flex items-center justify-center">
              <div class="w-64 h-64 border border-lavender-soft/20 rounded-full animate-spin-slower"></div>
            </div>
            <div class="absolute inset-0 flex items-center justify-center">
              <div class="w-80 h-80 border border-neural-teal/10 rounded-full animate-spin-slowest"></div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Core Concepts -->
    <section class="max-w-7xl mx-auto px-6 py-20">
      <h2 class="text-4xl font-display font-bold text-center mb-12 bg-gradient-to-r from-golden-glow to-neural-teal bg-clip-text text-transparent">
        Understanding the Foundation
      </h2>
      
      <div class="grid md:grid-cols-3 gap-8">
        <Card>
          <div class="text-4xl mb-4">🧠</div>
          <h3 class="text-xl font-semibold text-neural-teal mb-3">The Default Mode Network</h3>
          <p class="text-slate-400 mb-4">
            Discover how your brain's "idle mode" shapes creativity, self-awareness, and how you think about thinking.
          </p>
          <a href="/insights" class="text-golden-glow hover:text-golden-core transition-colors inline-flex items-center gap-2">
            Learn More
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
            </svg>
          </a>
        </Card>

        <Card>
          <div class="text-4xl mb-4">🤖</div>
          <h3 class="text-xl font-semibold text-neural-teal mb-3">AI Attention Mechanisms</h3>
          <p class="text-slate-400 mb-4">
            Explore parallels between AI's attention systems and human cognitive focus—and what it means for collaboration.
          </p>
          <a href="/insights" class="text-golden-glow hover:text-golden-core transition-colors inline-flex items-center gap-2">
            Learn More
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
            </svg>
          </a>
        </Card>

        <Card>
          <div class="text-4xl mb-4">🔄</div>
          <h3 class="text-xl font-semibold text-neural-teal mb-3">Mindful Integration</h3>
          <p class="text-slate-400 mb-4">
            Practical strategies for maintaining cognitive health while working alongside AI systems daily.
          </p>
          <a href="/exercises" class="text-golden-glow hover:text-golden-core transition-colors inline-flex items-center gap-2">
            Start Practicing
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
            </svg>
          </a>
        </Card>
      </div>
    </section>

    <!-- Featured Insights -->
    {featuredInsights.length > 0 && (
      <section class="max-w-7xl mx-auto px-6 py-20">
        <h2 class="text-4xl font-display font-bold text-center mb-12 bg-gradient-to-r from-golden-glow to-neural-teal bg-clip-text text-transparent">
          Featured Insights
        </h2>
        
        <div class="grid md:grid-cols-3 gap-8">
          {featuredInsights.map((insight) => (
            <Card href={`/insights/${insight.slug}`}>
              <div class="mb-3">
                <span class="text-xs uppercase tracking-wide text-neural-teal font-semibold">
                  {insight.data.difficulty}
                </span>
              </div>
              <h3 class="text-xl font-semibold mb-3 text-slate-100 group-hover:text-neural-teal transition-colors">
                {insight.data.title}
              </h3>
              <p class="text-slate-400 text-sm mb-4">
                {insight.data.excerpt}
              </p>
              <div class="flex items-center gap-4 text-xs text-slate-500">
                <span>{insight.data.date.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })}</span>
                <span>•</span>
                <span>{insight.data.readingTime} min read</span>
              </div>
            </Card>
          ))}
        </div>

        <div class="text-center mt-12">
          <a href="/insights" class="inline-block px-6 py-3 bg-gradient-to-r from-golden-core to-golden-glow rounded-lg text-cosmic-deep font-semibold hover:shadow-glow-md transition-all duration-300">
            View All Insights
          </a>
        </div>
      </section>
    )}
  </main>

  <Footer />
</BaseLayout>

<style>
  @keyframes spin-slow {
    from { transform: rotate(0deg); }
    to { transform: rotate(360deg); }
  }
  @keyframes spin-slower {
    from { transform: rotate(0deg); }
    to { transform: rotate(-360deg); }
  }
  @keyframes spin-slowest {
    from { transform: rotate(0deg); }
    to { transform: rotate(360deg); }
  }
  .animate-spin-slow {
    animation: spin-slow 20s linear infinite;
  }
  .animate-spin-slower {
    animation: spin-slower 30s linear infinite;
  }
  .animate-spin-slowest {
    animation: spin-slowest 40s linear infinite;
  }
</style>