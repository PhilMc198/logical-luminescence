---
interface Props {
  title: string;
  description?: string;
}

const { title, description = "Illuminating the intersection of human cognition and artificial intelligence" } = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    
    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Space+Grotesk:wght@400;600;700&family=Fira+Code:wght@400;500&display=swap" rel="stylesheet">
    
    <title>{title} | Logical Luminescence</title>
  </head>
  <body class="bg-gradient-to-br from-cosmic-deep to-cosmic-blue min-h-screen text-slate-200">
    <!-- Cosmic Background -->
    <div class="fixed inset-0 overflow-hidden pointer-events-none">
      <div class="absolute top-1/5 left-1/3 w-96 h-96 bg-neural-teal/10 rounded-full blur-3xl"></div>
      <div class="absolute bottom-1/4 right-1/4 w-80 h-80 bg-golden-core/10 rounded-full blur-3xl"></div>
      <div class="absolute top-2/5 left-3/4 w-64 h-64 bg-lavender-soft/5 rounded-full blur-3xl"></div>
    </div>

    <!-- Content -->
    <div class="relative z-10">
      <slot />
    </div>
  </body>
</html>