---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
}

const {
  title,
  description = 'Exploring the inner life, the technological reality, and the political stakes of a world transformed by AI.',
  ogImage,
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const currentPath = Astro.url.pathname;

const navLinks = [
  { href: '/start-here', label: 'Start here' },
  { href: '/essays',     label: 'Essays' },
  { href: '/practices',  label: 'Practices' },
  { href: '/reading-list', label: 'Reading list' },
  { href: '/about',      label: 'About' },
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />

    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:type" content="website" />
    {ogImage && <meta property="og:image" content={ogImage} />}

    <title>{title}</title>

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  </head>

  <body>
    <header class="site-header">
      <nav class="site-nav container--narrow" style="max-width: 860px;">
        <a href="/" class="nav-brand">Logical Luminescence</a>
        <ul class="nav-links" role="list">
          {navLinks.map(({ href, label }) => (
            <li>
              <a
                href={href}
                class:list={['nav-link', { active: currentPath.startsWith(href) }]}
              >
                {label}
              </a>
            </li>
          ))}
        </ul>
        <button class="nav-toggle" aria-label="Toggle menu" aria-expanded="false">
          <span></span><span></span><span></span>
        </button>
      </nav>
    </header>

    <main>
      <slot />
    </main>

    <footer class="site-footer">
      <div class="footer-inner container--narrow" style="max-width: 860px;">
        <span class="footer-brand">Logical Luminescence</span>
        <span class="footer-note">Melbourne, Australia — thinking in public</span>
      </div>
    </footer>
  </body>
</html>

<script>
  const toggle = document.querySelector('.nav-toggle') as HTMLButtonElement;
  const links = document.querySelector('.nav-links') as HTMLElement;
  if (toggle && links) {
    toggle.addEventListener('click', () => {
      const open = toggle.getAttribute('aria-expanded') === 'true';
      toggle.setAttribute('aria-expanded', String(!open));
      links.classList.toggle('nav-links--open', !open);
    });
  }
</script>

<style>
  .site-header {
    border-bottom: 0.5px solid var(--color-border);
    background: var(--color-ground);
    position: sticky;
    top: 0;
    z-index: 10;
  }

  .site-nav {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 1.1rem 1.5rem;
    gap: 2rem;
  }

  .nav-brand {
    font-family: var(--font-serif);
    font-size: 1.05rem;
    font-weight: 500;
    color: var(--color-ink);
    white-space: nowrap;
    flex-shrink: 0;
  }

  .nav-links {
    display: flex;
    list-style: none;
    gap: 2rem;
    align-items: center;
  }

  .nav-link {
    font-size: 12px;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--color-ink-muted);
    transition: color 0.15s;
  }

  .nav-link:hover { color: var(--color-ink); }

  .nav-link.active {
    color: var(--color-ink);
    border-bottom: 1px solid var(--color-ink);
    padding-bottom: 1px;
  }

  .nav-toggle {
    display: none;
    flex-direction: column;
    gap: 5px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 4px;
  }

  .nav-toggle span {
    display: block;
    width: 22px;
    height: 1px;
    background: var(--color-ink);
  }

  .site-footer {
    border-top: 0.5px solid var(--color-border);
    margin-top: var(--space-xl);
  }

  .footer-inner {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 1.5rem;
    gap: 1rem;
  }

  .footer-brand {
    font-family: var(--font-serif);
    font-size: 0.9rem;
    color: var(--color-ink-faint);
  }

  .footer-note {
    font-size: 11px;
    color: var(--color-ink-faint);
  }

  @media (max-width: 640px) {
    .nav-links {
      display: none;
      flex-direction: column;
      position: absolute;
      top: 100%;
      left: 0;
      right: 0;
      background: var(--color-ground);
      border-bottom: 0.5px solid var(--color-border);
      padding: 1rem 1.5rem;
      gap: 1.25rem;
    }

    .nav-links--open { display: flex; }

    .nav-toggle { display: flex; }

    .footer-inner { flex-direction: column; align-items: flex-start; gap: 0.4rem; }
  }
</style>
